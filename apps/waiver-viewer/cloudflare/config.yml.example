# Example cloudflared tunnel config for waiver viewer + API on one hostname.
# Copy to ~/.cloudflared/config.yml (or pass with --config) and replace placeholders.

tunnel: <TUNNEL_UUID>
credentials-file: C:\Users\<you>\.cloudflared\<TUNNEL_UUID>.json

ingress:
  # API (Express) — must receive Cf-Access-Jwt-Assertion from Cloudflare
  - path: /api/*
    service: http://127.0.0.1:3001

  # Static waiver viewer (vite build output)
  - path: /*
    service: http://127.0.0.1:5176
    # For production static hosting, point to a file server instead, e.g.:
    # service: file://C:/path/to/apps/waiver-viewer/dist

  - service: http_status:404
